// Structured error handling in Codong
fn divide(a, b) {
    if b == 0 {
        return error.new("E_MATH", "division by zero",
            fix: "ensure divisor is not zero",
            retry: false
        )
    }
    return a / b
}

// Using ? operator for error propagation
fn safe_divide(a, b) {
    result = divide(a, b)?
    return "Result: {result}"
}

// try/catch
try {
    answer = divide(10, 0)?
    print(answer)
} catch err {
    print("Error: {err.code}")
    print("Message: {err.message}")
    print("Fix: {err.fix}")
}

// Normal case
print(divide(10, 3))
