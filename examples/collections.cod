// Collection operations in Codong

// List operations
nums = [5, 3, 8, 1, 9, 2, 7]
nums.sort()
print("Sorted: {nums.join(", ")}")

// Higher-order functions
doubled = nums.map(fn(x) => x * 2)
print("Doubled: {doubled.join(", ")}")

evens = nums.filter(fn(x) => x % 2 == 0)
print("Evens: {evens.join(", ")}")

sum = nums.reduce(fn(acc, x) => acc + x, 0)
print("Sum: {sum}")

// Map operations
user = {name: "Ada", age: 30, role: "engineer"}
user.email = "ada@codong.org"

print("Name: {user.name}")
print("Keys: {user.keys().join(", ")}")

// Immutable merge
defaults = {theme: "dark", lang: "en"}
prefs = {theme: "light"}
config = defaults.merge(prefs)
print("Theme: {config.theme}")
print("Defaults unchanged: {defaults.theme}")
